rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== COLEÇÃO: produtos =====
    match /produtos/{produtoId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // ===== COLEÇÃO: categorias =====
    match /categorias/{categoriaId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // ===== COLEÇÃO: pedidos =====
    match /pedidos/{pedidoId} {
      // Cliente pode criar novo pedido
      allow create: if request.auth != null;

      // Cliente pode acessar seus próprios pedidos
      allow read, update, delete: if request.auth != null &&
                                   request.auth.uid == resource.data.uid;

      // Admin pode acessar e gerenciar todos os pedidos
      allow read, write: if request.auth != null && request.auth.token.admin == true;

      // ===== Subcoleção: downloads (registro de eBooks baixados) =====
      match /downloads/{downloadId} {
        allow create: if request.auth != null &&
                      request.auth.uid == downloadId;
        allow read: if request.auth != null &&
                    request.auth.uid == downloadId;
      }
    }

    // ===== COLEÇÃO: cupons =====
    match /cupons/{cupomId} {
      allow read, write: if request.auth != null && request.auth.token.admin == true;
    }

    // ===== COLEÇÃO: usuarios =====
    match /usuarios/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      allow read, write: if request.auth != null && request.auth.token.admin == true;
    }
  }
}
